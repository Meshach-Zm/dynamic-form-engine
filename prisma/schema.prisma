generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url and directUrl are now configured in prisma.config.ts
}

model FormTemplate {
  id        String        @id @default(cuid())
  name      String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  versions  FormVersion[]
}

model FormVersion {
  id             String       @id @default(cuid())
  versionNumber  Int
  schema         Json
  isLatest       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  formTemplateId String
  formTemplate   FormTemplate @relation(fields: [formTemplateId], references: [id], onDelete: Cascade)
  submissions    Submission[]

  @@unique([formTemplateId, versionNumber])
  @@index([formTemplateId, isLatest])
}

model Submission {
  id            String      @id @default(cuid())
  payload       Json
  files         Json?
  createdAt     DateTime    @default(now())
  formVersionId String
  formVersion   FormVersion @relation(fields: [formVersionId], references: [id], onDelete: Restrict)

  @@index([formVersionId])
  @@index([formVersionId, createdAt(sort: Desc)])
}
