# ------------------------------------------------------------------------------
# APP CONFIGURATION

# ------------------------------------------------------------------------------
# DATABASE: NEON (PostgreSQL)
# ------------------------------------------------------------------------------
# 1. DATABASE_URL: Use the "Pooled" connection string from Neon. 
# Best for serverless functions (Vercel/AWS Lambda).
# If using Prisma, add '?pgbouncer=true' at the end.
DATABASE_URL="postgresql://user:password@ep-cool-darkness-123456-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# 2. DIRECT_URL: Use the "Direct" connection string from Neon.
# Required for database migrations (e.g., 'npx prisma migrate dev').
DIRECT_URL="postgresql://user:password@ep-cool-darkness-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ------------------------------------------------------------------------------
# STORAGE: CLOUDINARY
# ------------------------------------------------------------------------------
# Used for processing the 'profilePicture' field in your JSON schema
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret